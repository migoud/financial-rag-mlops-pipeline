"""Creation of a evaluation dataset"""
import pandas as pd

print("Creating evaluation dataset...")

# Step 1: Define realistic prompts and attach the specific context blocks 
# extracted from your BigQuery tables.
eval_data = {
    "prompt": [
        "How did Canada's GDP per capita shift relative to US inflation between 2016 and 2019?",
        "What was the local currency GDP per capita for Canada in 2020?",
        "Compare the US CPI index value between 2018 and 2020 based on the database."
    ],
    "context": [
        "year: 2019 country_code: CAN us_cpi: 255.657 gdp_per_capita_local_currency: 52100.5\nyear: 2016 country_code: CAN us_cpi: 240.007 gdp_per_capita_local_currency: 48500.2",
        "year: 2020 country_code: CAN us_cpi: 258.811 gdp_per_capita_local_currency: 50300.1",
        "year: 2020 country_code: USA us_cpi: 258.811 gdp_per_capita_local_currency: 63500.4\nyear: 2018 country_code: USA us_cpi: 251.107 gdp_per_capita_local_currency: 62900.2"
    ],
    "reference": [
        "From 2016 to 2019, Canada's GDP per capita grew from 48,500.2 CAD to 52,100.5 CAD while US inflation (CPI) increased from 240.007 to 255.657.",
        "In 2020, Canada's local currency GDP per capita was 50,300.1 CAD.",
        "The US CPI was 251.107 in 2018 and rose to 258.811 by 2020."
    ]
}

# Step 2: Convert to a standard Pandas DataFrame
# The Gen AI evaluation service automatically detects 'prompt', 'context', and 'reference' columns!
your_prepared_eval_dataframe = pd.DataFrame(eval_data)



print(f"Dataset successfully created with {len(your_prepared_eval_dataframe)} test cases.")
your_prepared_eval_dataframe.head()


""" Initialize and run evaluation job """

import vertexai
from vertexai.evaluation import EvalTask

# 1. Initialize Context
PROJECT_ID = "project-2e0885aa-8f3e-4da5-86a"
LOCATION = "us-central1"
vertexai.init(project=PROJECT_ID, location=LOCATION)

print("Configuring local-first evaluation task...")
# FIXED: Replaced 'fulfillment' with the official string identifier 'instruction_following'
eval_task = EvalTask(
    dataset=your_prepared_eval_dataframe,
    metrics=[
        "groundedness", 
        "instruction_following"
    ]
)

print("Executing Step 3: Running the local-first automated evaluation job...")
eval_result = eval_task.evaluate(
    model="gemini-2.5-flash", 
    prompt_template="{prompt} using context: {context}"
)

print("\n--- VERTEX AI EVALUATION SUMMARY ---")
print(eval_result.summary_metrics)

print("\n--- DETAILED ROW-BY-ROW INSIGHTS ---")
eval_result.metrics_table.head()
