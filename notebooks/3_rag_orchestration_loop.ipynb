""" Start of RAG orchestration loop """
from google import genai
from google.cloud import bigquery

# 1. Project Configuration
PROJECT_ID = "project-2e0885aa-8f3e-4da5-86a"
LOCATION = "us-central1"  

print(f"Initializing Clients (Region: {LOCATION})...")
# Modern SDK Client initialization
client = genai.Client(vertexai=True, project=PROJECT_ID, location=LOCATION)
bq_client = bigquery.Client(project=PROJECT_ID)

# 2. Extract Data Context from BigQuery
print("Querying features from BigQuery...")
query = f"""
    SELECT year, country_code, us_cpi, gdp_per_capita_local_currency 
    FROM `{PROJECT_ID}.finance_ml_engine.cleaned_features` 
    ORDER BY year DESC, country_code ASC 
    LIMIT 10
"""
results = bq_client.query(query).to_dataframe()
data_context = results.to_string(index=False)

# 3. Construct the RAG Prompt
user_question = "Based on the provided data, how did Canada's GDP per capita (in CAD) shift relative to US inflation over the last few recorded years?"

rag_prompt = f"""
You are a financial analysis assistant. You must answer the user's question using ONLY the factual data provided below. If the answer cannot be determined from the data, state that clearly.

Note: gdp_per_capita_local_currency is in CAD for Canada (CAN) and USD for the United States (USA).

---
DATA CONTEXT:
{data_context}
---

USER QUESTION: {user_question}
"""

# 4. Generate Content Natively via the Client
print("Sending context to Gemini...")
response = client.models.generate_content(
    model="gemini-2.5-flash",  # UPDATED: Using the current stable production model tag
    contents=rag_prompt
)

print("\n--- VERTEX AI ENTERPRISE RAG RESPONSE ---")
print(response.text)
