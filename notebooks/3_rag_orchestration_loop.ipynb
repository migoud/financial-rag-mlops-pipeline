from google import genai
from google.cloud import bigquery

# Initialize the Gemini Client targeted at your project metadata
PROJECT_ID = "project-2e0885aa-8f3e-4da5-86a"
client = genai.Client(
    enterprise=True, 
    project=PROJECT_ID, 
    location="us-central1"
)

# Connect to the BigQuery storage schema to collect features
bq_client = bigquery.Client(project=PROJECT_ID)

query = f"""
    SELECT year, us_cpi, gdp_per_capita 
    FROM `{PROJECT_ID}.finance_ml_engine.cleaned_features` 
    ORDER BY year DESC LIMIT 5
"""
query_job = bq_client.query(query)
results = query_job.to_dataframe()
data_context = results.to_string(index=False)

user_question = "Based on the provided data, how did Canada's GDP per capita shift relative to US inflation over the last few recorded years?"

rag_prompt = f"""
You are a financial analysis assistant. You must answer the user's question using ONLY the factual data provided below. If the answer cannot be determined from the data, state that clearly.

---
DATA CONTEXT:
{data_context}
---

USER QUESTION: {user_question}
"""

# Call the generation service using the enterprise-routed mainline identifier
response = client.models.generate_content(
    model="gemini-2.5-flash",
    contents=rag_prompt
)

print("--- GEMINI ENTERPRISE RAG RESPONSE ---")
print(response.text)
